# คัดลอกไฟล์นี้เป็น .env แล้วใส่ค่าจริง
# (Vercel: ใส่ที่ Project Settings > Environment Variables)

# Supabase Project (Settings > API)
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi....SERVICE_ROLE_KEY

# JWT secret สำหรับ sign token (สุ่มยาวๆ เช่น openssl rand -hex 32)
JWT_SECRET=replace-with-long-random-string

# Optional: limit CORS origin (default: *)
CORS_ORIGIN=*
